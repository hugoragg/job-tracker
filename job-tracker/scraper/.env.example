# Supabase — use the service_role key (bypasses RLS; never expose to frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Resend — for the daily digest email
RESEND_API_KEY=re_your_api_key

# Email addresses
EMAIL_FROM=tracker@yourdomain.com   # must be a verified sender in Resend
EMAIL_TO=you@example.com

# Anthropic — used by ai_filter.py to filter jobs through Claude before the digest
# If unset, the email is sent unfiltered (fail-open).
ANTHROPIC_API_KEY=sk-ant-your-key

# Set to "1" on Railway so the scrape only runs at 07:00 Madrid local time.
# Leave unset for ad-hoc / dev runs (always executes).
SCHEDULED_RUN=
